# База API. При деплое за reverse-proxy под одним доменом ставьте относительный
# путь (пусто/origin фронта) — браузер пойдёт на тот же домен. Локально:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Включить экран ввода UUID-ключа на клиентской части (в паре с T2R_ACCESS_KEY).
# В проде: 1. В dev: 0/не задано.
NEXT_PUBLIC_REQUIRE_ACCESS_KEY=0
