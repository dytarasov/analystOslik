# --- App ---
# В проде: T2R_ENV=prod (включает Secure-cookie, JSON-логи, HSTS).
T2R_ENV=dev
T2R_LOG_LEVEL=INFO
# Через запятую. В проде укажите реальный origin фронта, например https://oslik.example.com
T2R_CORS_ORIGINS=http://localhost:3000
# Необязательно (по умолчанию выводится из T2R_ENV): форсировать JSON-логи / Secure-cookie.
# T2R_JSON_LOGS=true
# T2R_COOKIE_SECURE=true

# --- Access gate (клиентская часть) ---
# UUID-ключ доступа к чату-аналитику. Пусто → гейт ВЫКЛЮЧЕН (dev).
# В проде задайте случайный UUID: python -c "import uuid; print(uuid.uuid4())"
# и включите экран ввода на фронте: NEXT_PUBLIC_REQUIRE_ACCESS_KEY=1
T2R_ACCESS_KEY=

# --- Admin auth ---
# bcrypt hash, generate via: python -m scripts.create_admin_hash <password>
T2R_ADMIN_LOGIN=admin
T2R_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_ME
T2R_JWT_SECRET=replace-me-with-random-32-bytes
T2R_JWT_TTL_SECONDS=86400

# Fernet key for encrypting data source credentials.
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
T2R_ENCRYPTION_KEY=replace-me-fernet-key

# --- Databases ---
T2R_PG_DSN=postgresql+asyncpg://t2r:t2r@postgres:5432/t2r
T2R_NEO4J_URI=bolt://neo4j:7687
T2R_NEO4J_USER=neo4j
T2R_NEO4J_PASSWORD=t2r_neo4j_pass

# --- LLM (OpenAI compatible) ---
T2R_LLM_API_URL=https://api.deepseek.com/v1
T2R_LLM_API_KEY=sk-replace-me
T2R_LLM_MODEL=deepseek-chat
T2R_LLM_TEMPERATURE=0.2
T2R_LLM_MAX_TOKENS=4096
# Ретраи SDK на 429/5xx/timeout (с backoff) — обработка rate-limit. 3 гасит 429.
T2R_LLM_MAX_RETRIES=3
# OpenRouter: по умолчанию провайдер НЕ пиннится — свободная маршрутизация с
# фолбэками (один сыплющий 429 провайдер не блокирует всё). Чтобы предпочесть
# один провайдер: T2R_LLM_OPENROUTER_PIN=1 + T2R_LLM_OPENROUTER_PROVIDER=Friendli
# (фолбэки всё равно остаются — это предпочтение, а не жёсткий пин).
# T2R_LLM_OPENROUTER_PIN=0
# T2R_LLM_OPENROUTER_PROVIDER=Friendli

# --- Embeddings (OpenAI compatible) ---
# ВАЖНО: T2R_EMB_DIM должен совпадать с размерностью колонки md_notes.embedding
# (vector(1024), см. migrations/0010). Дефолтная модель bge-m3 нативно 1024-мерная.
# При смене модели на 1536-мерную (напр. text-embedding-3-small) сначала измените
# размерность колонки миграцией — иначе запись эмбеддингов будет молча падать и RAG
# перестанет находить заметки.
T2R_EMB_API_URL=https://openrouter.ai/api/v1
T2R_EMB_API_KEY=sk-replace-me
T2R_EMB_MODEL=BAAI/bge-m3
T2R_EMB_DIM=1024

# --- ClickHouse defaults ---
T2R_CH_DEFAULT_MAX_EXECUTION_TIME=30
T2R_CH_DEFAULT_LIMIT=10000

# --- SSE ---
T2R_SSE_PING_INTERVAL=15

# --- Rate limit (slowapi, по IP; за reverse-proxy нужен X-Forwarded-For) ---
T2R_CLIENT_RATE_LIMIT=10/minute
T2R_ACCESS_RATE_LIMIT=10/minute
T2R_ADMIN_LOGIN_RATE_LIMIT=5/minute

# --- Export ---
T2R_EXPORT_DIR=/var/t2r/exports
